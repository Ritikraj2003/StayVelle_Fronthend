{
  "name": "stayvelle",
  "version": "1.0.0",
  "author": "Pyush Production",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron-start": "ng build --base-href ./ && electron .",
    "build-desktop": "node build-desktop.js"
  },
  "private": true,
  "build": {
    "appId": "com.stayvelle.app",
    "productName": "Stayvelle",
    "copyright": "Copyright © 2024 Stayvelle",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/stayvelle/**",
      "electron/main.js",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stayvelle"
    }
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.16.0",
    "@angular/animations": "^17.3.0",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@ng-bootstrap/ng-bootstrap": "^16.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.2",
    "chart.js": "^4.5.1",
    "core-js": "^3.48.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.3.0",
    "@angular/localize": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "electron": "^34.3.1",
    "electron-builder": "^24.13.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "typescript": "~5.4.2"
  }
}
